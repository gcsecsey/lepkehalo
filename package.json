{
  "name": "lepkehalo",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "expo lint",
    "build:e2e:ios": "detox build --configuration ios.sim.release",
    "build:e2e:android": "detox build --configuration android.emu.release",
    "test:e2e:ios": "detox test --configuration ios.sim.release",
    "test:e2e:android": "detox test --configuration android.emu.release",
    "test:e2e": "npm run test:e2e:ios && npm run test:e2e:android",
    "seed": "node scripts/seed-books.mjs",
    "seed:android": "node scripts/seed-books.mjs android",
    "seed:ios": "node scripts/seed-books.mjs ios",
    "seed:clear": "node scripts/seed-books.mjs --clear",
    "seed:clear:android": "node scripts/seed-books.mjs --clear android",
    "seed:clear:ios": "node scripts/seed-books.mjs --clear ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.10.0",
    "@shopify/flash-list": "2.0.2",
    "axios": "^1.13.2",
    "expo": "~54.0.31",
    "expo-build-properties": "^1.0.10",
    "expo-camera": "^17.0.10",
    "expo-haptics": "^15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-inappbrowser-reborn": "^3.7.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.0",
    "@vitejs/plugin-react": "^5.1.4",
    "detox": "^20.46.3",
    "msw": "^2.12.7",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "private": true
}
